# PostgreSQL (Supabase → Settings → Database → Connection string)
#
# Uygulama (Transaction pooler, port 6543):
DATABASE_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
#
# Prisma migrate (Session pooler, port 5432 — db.[ref].supabase.co yerine):
# db.[ref].supabase.co yalnızca IPv6; birçok Windows ağında migrate P1001 verir.
DIRECT_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-1-eu-central-1.pooler.supabase.com:5432/postgres?sslmode=require"

NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
# Production: https://your-app.vercel.app (sonunda / olmasın, başında protokol şart)
# UYARI: Yalnızca host yazmayın ("asir-sepeti.vercel.app" yanlış); NextAuth callback üretemez.
NEXTAUTH_URL="http://localhost:3000"

# Giriş (/giris): db seed bu kullanıcıyı oluşturur — npm run db:seed veya npx prisma db seed
ADMIN_EMAIL="admin@asirsepeti.com"
ADMIN_PASSWORD="change-this-strong-admin-password"

# İşletmeler grid günlük arşiv — Vercel Cron: GET /api/cron/close-company-grid-day
# Authorization: Bearer <CRON_SECRET> veya header x-cron-secret (Vercel ortam değişkeninde aynı değeri tanımlayın)
CRON_SECRET="long-random-string"

# Gelen WhatsApp / SMS webhook (POST /api/webhooks/whatsapp)
# İstek: header x-webhook-secret veya ?secret= veya Authorization: Bearer …
INBOUND_WEBHOOK_SECRET="long-random-string"
# true ise parse başarılı mesajlar yarın (UTC+1 gün) teslim için otomatik ana sipariş oluşturur
WHATSAPP_AUTO_CREATE_ORDER="false"

# Supabase Storage — aylık menü PDF (imzalı URL). Bucket: monthly-menus (private).
# Sunucu tarafında ikisi de dolu olmalı (biri eksikse müşteri ekranında menü düğmesi çıkmaz):
#   SUPABASE_URL="https://xxxx.supabase.co"
#   veya aynı değer: NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
#   SUPABASE_SERVICE_ROLE_KEY="..."  (yalnızca sunucu; asla NEXT_PUBLIC_ öneki kullanmayın)
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare Turnstile (kayıt formunda bot koruması) — opsiyonel.
# Her ikisi de doluysa POST /api/auth/register turnstileToken zorunlu olur ve
# /kayit sayfasında widget render edilir. Boşsa Turnstile atlanır.
#   1) https://dash.cloudflare.com/?to=/:account/turnstile sitenize widget ekleyin.
#   2) Domain'i Vercel canlı URL'iniz ile sınırlandırın.
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
